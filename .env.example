# SleuthPro API — Environment Variables
# Copy this to .env.local for local development
# In production, add these to Vercel → Project → Settings → Environment Variables

# Melissa Data License Key (get from app.melissa.com → License Keys)
MELISSA_LICENSE_KEY=your_melissa_license_key_here

# IRB Search credentials (add when IRB account is approved — Deep Dive feature)
# IRB_API_KEY=your_irb_api_key_here
# IRB_API_SECRET=your_irb_api_secret_here